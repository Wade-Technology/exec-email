# exec-email — environment template (non-secret).
# In production these come from /opt/wtec/.env on Hetzner.

ASPEN_ADMIN_URL=http://aspen-admin-backend:8001
ADMIN_API_KEY=                       # required, lives in /opt/wtec/.env

WADE_BCC_EMAIL=wadethomaswarren@gmail.com

IMAP_HOST=imap.migadu.com
IMAP_PORT=993
SMTP_HOST=smtp.migadu.com
# Port 465 (implicit TLS) is blocked by the Hetzner outbound firewall.
# Use 587 with STARTTLS. aiosmtplib.send() must pair this with start_tls=True.
SMTP_PORT=587

POLL_INTERVAL_FALLBACK=30
MAX_THREAD_TURNS=3

# Public-mailbox abuse limits. An attacker who emails an exec address
# 1000 times must NOT be able to trigger 1000 LLM calls / SMTP sends.
# Per-sender hourly cap: at most N inbound messages from one address
# per role per hour will be processed. Excess is silently \Seen-marked
# and dropped (one heads-up to Wade per sender per day).
MAX_PER_SENDER_PER_HOUR=5
# Per-role 24h hard cap (sum across all senders). Once tripped, the
# role stops processing inbound until the rolling window relaxes.
MAX_PER_ROLE_PER_DAY=50

DB_HOST=wtec-postgres
DB_PORT=5432
DB_USER=wtec
DB_PASSWORD=
DB_NAME=wtec

# Nesta conversations double-log. Every inbound + outbound is ALSO
# written to nesta's `conversations` table so MC /communications shows
# Exec traffic alongside Nesta mail. The exec_email_threads schema
# above remains authoritative — this is fire-and-forget logging only.
# If these are unset or the DB is unreachable, logging is silently
# disabled and exec-email runs normally.
NESTA_DB_HOST=nesta-money-postgres
NESTA_DB_PORT=5432
NESTA_DB_USER=app_user
NESTA_DB_PASSWORD=
NESTA_DB_NAME=teller
# All Exec rows are inserted under Wade's tenant_id.
WADE_TENANT_ID=fe0f026f-1bff-497e-b623-3c303cd00699

# Per-exec mailbox passwords. Populated by scripts/provision-exec-mailboxes.sh
# in the docker repo. An exec without a password is silently skipped.
EXEC_EMAIL_CEO_PASSWORD=
EXEC_EMAIL_CTO_PASSWORD=
EXEC_EMAIL_COO_PASSWORD=
EXEC_EMAIL_CSO_PASSWORD=
EXEC_EMAIL_CFO_PASSWORD=
EXEC_EMAIL_CRO_PASSWORD=
EXEC_EMAIL_CCIO_PASSWORD=
EXEC_EMAIL_HIGGINSDEV_PASSWORD=
